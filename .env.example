# OpenDQV Configuration
# Copy this to .env and fill in your values

# Auth mode: "open" (no auth, for dev/POC) or "token" (PAT required, for production)
AUTH_MODE=open

# JWT Secret Key (required when AUTH_MODE=token)
SECRET_KEY=change-me-to-a-random-secret-key

# API URL (used by Streamlit UI)
API_URL=http://localhost:8000

# UI access token — if set, the Streamlit workbench requires this token before
# displaying. Provides a shared-secret gate for the UI. Empty = no gate (dev default).
# For production, ALSO restrict port 8501 to your corporate network or VPN.
# UI_ACCESS_TOKEN=

# Token expiry in days
TOKEN_EXPIRY_DAYS=30

# Rate limits (raise for load testing, lower for production)
RATE_LIMIT_VALIDATE=300/minute
RATE_LIMIT_DEFAULT=300/minute

# Gunicorn worker count.
# Default: 1 — safe for any hardware. OpenDQV's validate endpoint is CPU-bound,
# not I/O-bound, so the standard "(2 x cores) + 1" formula does not apply.
# Benchmark your hardware before increasing: more workers can INCREASE latency
# on hyperthreaded CPUs. See Dockerfile for benchmark results.
WEB_CONCURRENCY=1

# Node identity — tags every contract history snapshot with its origin.
# Defaults to the machine hostname. Set explicitly for multi-node deployments.
# e.g. OPENDQV_NODE_ID=eu-west-1
# OPENDQV_NODE_ID=
