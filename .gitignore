__pycache__/
*.pyc
.venv/
.env
opendqv.db
*.db
.pytest_cache/
.mypy_cache/
dist/
*.egg-info/

# Runtime PID lock files (machine-specific, never commit)
.opendqv_*.lock

# OpenAPI spec — generated dynamically by FastAPI at runtime (/openapi.json, /docs, /redoc)
# Never commit the static file; it will always drift. Let FastAPI serve the live spec.
openapi.json

# Customer-specific demo menus — never commit prospect names to the public repo
scripts/ppds_demo_customers.local.json

# Importer artifact contracts — created by ODCS/GX importers when input has no title/name.
# These are user-generated artifacts, not part of the curated contract library.
contracts/imported_contract.yaml
contracts/unnamed_suite.yaml
contracts/unnamed_model.yaml
contracts/unnamed_source.yaml
contracts/unnamed_table.yaml
contracts/imported.yaml
